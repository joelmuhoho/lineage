# ==========================================
# Lineage Environment Variables Template
# ==========================================
# Instructions: Copy this file, rename it to '.env',
# and replace the dummy values with your actual configuration.

# --- Flask Configuration ---
FLASK_APP=run.py
FLASK_ENV=development
# Generate a secure key using: python -c 'import secrets; print(secrets.token_hex(16))'
SECRET_KEY=your_super_secret_key_here
# Salt for token generation (email verification/password resets)
SALT=your_super_secret_salt_here

# --- Database Configuration ---
# SQLite (Development)
LINEAGE_DATABASE_URI=sqlite:///lineage.db
# PostgreSQL (Production Example)
# LINEAGE_DATABASE_URI=postgresql://user:password@localhost/lineage_db
SQLALCHEMY_ECHO=False

# --- Email Server Configuration (SMTP) ---
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your_app_email@outlook.com
MAIL_PASSWORD=your_app_email_password
ADMINS=admin1@example.com,admin2@example.com

# --- Guest User Account ---
# Used for the "Login as Guest" feature on the landing page
GUEST_NAME=Guest User
GUEST_EMAIL=guest@example.com
GUEST_PASSWORD=guest_secure_password

# --- Deployment / Update Script Variables ---
ENVIRONMENT=development
BASH_SCRIPT_FILE_NAME=updateApplication.sh
REPOSITORY_NAME=lineage
MAIN_BRANCH_NAME=master
TESTING_BRANCH_NAME=testing